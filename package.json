{
	"name": "cosmonauts",
	"version": "0.1.0",
	"type": "module",
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./domains/shared/extensions"
		],
		"themes": [
			"./themes"
		]
	},
	"bin": {
		"cosmonauts": "./bin/cosmonauts"
	},
	"files": [
		"bundled/",
		"domains/",
		"lib/",
		"cli/",
		"bin/",
		"themes/"
	],
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"typecheck": "tsc --noEmit",
		"test": "node ./scripts/vitest-runner.mjs",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "0.70.2",
		"@mariozechner/pi-ai": "0.70.2",
		"@mariozechner/pi-coding-agent": "0.70.2",
		"typebox": "1.1.33",
		"commander": "^14.0.2",
		"gray-matter": "^4.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^3.0.0",
		"typescript": "^5.6.2",
		"vitest": "^3.0.0"
	}
}
